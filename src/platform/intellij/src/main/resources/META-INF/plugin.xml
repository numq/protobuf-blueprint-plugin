<idea-plugin>
    <id>com.numq.protobufblueprint</id>
    <name>Protobuf Blueprint</name>
    <vendor>numq</vendor>
    <depends>com.intellij.modules.platform</depends>
    <resource-bundle>messages.AppBundle</resource-bundle>
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                factoryClass="io.github.numq.protobufblueprint.platform.intellij.GeneratorToolWindowFactory"
                id="Protobuf Blueprint"
                icon="io.github.numq.protobufblueprint.platform.intellij.CustomIcons.LogoToolWindow"/>
    </extensions>
    <actions>
        <action id="com.numq.protobufblueprint.actions.OpenGeneratorToolWindowAction"
                class="io.github.numq.protobufblueprint.platform.intellij.OpenGeneratorToolWindowAction"
                icon="io.github.numq.protobufblueprint.platform.intellij.CustomIcons.LogoAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
